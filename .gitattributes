# Normalize line endings by default
* text=auto

# Shell scripts MUST use LF — CRLF breaks bash with "^M: command not found"
*.sh text eol=lf

# PowerShell scripts use CRLF — native Windows convention
*.ps1 text eol=crlf

# Markdown, YAML, and config files: use LF for consistency across OSes
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary